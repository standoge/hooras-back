{
  "name": "hooras-back",
  "version": "0.1.0",
  "description": "Social Hours Platform - Backend MVP",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "tsx node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "seed": "tsx node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
    "db:prepare": "tsx scripts/db-prepare.ts",
    "netlify:dev": "pnpm dlx netlify-cli dev",
    "netlify:deploy": "pnpm dlx netlify-cli deploy --prod",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "openapi:lint": "redocly lint openapi.yml",
    "openapi:docs": "redocly build-docs openapi.yml -o docs/api.html --title \"Social Hours Platform API\""
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.2.0",
    "pg": "^8.13.1",
    "serverless-http": "^3.2.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@redocly/cli": "^2.37.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
