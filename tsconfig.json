{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": "."
  },
  "include": [
    "index.ts",
    "app.ts",
    "app/**/*",
    "config/**/*",
    "core/**/*",
    "database/**/*",
    "knexfile.ts",
    "modules/**/*",
    "netlify/functions/**/*",
    "platform/**/*",
    "scripts/**/*",
    "server/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
