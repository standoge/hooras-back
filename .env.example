NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_hours
JWT_SECRET=change-me-in-production-use-long-random-string
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
WEBHOOK_SECRET=webhook-signing-secret-change-me
BASE_URL=http://localhost:3000
STUDENT_PROFILE_CACHE_TTL_MINUTES=30
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1
FIRECRAWL_TIMEOUT_MS=30000
# Maximum results returned per job search (1-25)
FIRECRAWL_MAX_RESULTS=10
N8N_WEBHOOK_URL=
N8N_API_KEY=
N8N_TIMEOUT_MS=15000
N8N_MAX_RETRIES=2

# CORS: * allows any origin; or comma-separated frontend URLs
CORS_ORIGINS=*
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Netlify: set SKIP_RUNTIME_MIGRATIONS=true in production (migrations run at build time)
# SKIP_RUNTIME_MIGRATIONS=true

# Storage: local (default) or netlify-blobs (auto-selected on Netlify/Lambda)
# STORAGE_BACKEND=local
# STORAGE_BACKEND=netlify-blobs
